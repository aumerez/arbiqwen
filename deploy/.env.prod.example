# Production environment for the single-ECS deployment.
# Copy to `.env` (gitignored) and fill in the values marked <...>.
#
#   cp .env.prod.example .env
#
# Only put non-public secrets here — this file is read by the backend container.

# ── Database (Postgres runs in-compose; pick a strong password) ────────────
POSTGRES_USER=arbi
POSTGRES_PASSWORD=<choose-a-strong-db-password>
POSTGRES_DB=arbi

# ── Auth ───────────────────────────────────────────────────────────────────
# 32+ byte random string. Generate: `openssl rand -hex 32`
JWT_SECRET=<openssl-rand-hex-32>

# ── LLM: Alibaba Cloud Model Studio (Qwen) ─────────────────────────────────
LLM_PROVIDER=alibaba
# DashScope / Model Studio API key from the Alibaba Cloud console.
DASHSCOPE_API_KEY=<your-model-studio-api-key>
# Qwen model. Options include qwen3.7-plus (balanced) or qwen3.7-max (strongest).
DASHSCOPE_MODEL=qwen3.7-plus
# International endpoint. If your account is on the mainland-China site, use
# https://dashscope.aliyuncs.com/compatible-mode/v1 instead.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── Embeddings: DashScope (Qwen text-embedding-v3, 1024-dim) ────────────────
EMBEDDING_PROVIDER=dashscope
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSION=1024

# ── Runtime ────────────────────────────────────────────────────────────────
ENVIRONMENT=production
MAX_UPLOAD_SIZE_MB=25
# RAG reranking uses a local cross-encoder (BAAI/bge-reranker-large, ~1.3 GB,
# downloaded on first use — needs ~4 GB+ RAM). Set to false on a small ECS to
# skip the local model entirely (retrieval still works, just unranked).
ENABLE_RERANKER=false
# Same-origin deployment (nginx serves the SPA and proxies the API), so CORS is
# not exercised. Set this to your public URL only if you split the web onto a
# separate origin (e.g. Vercel): CORS_ALLOWED_ORIGINS=https://demo.example.com
CORS_ALLOWED_ORIGINS=http://localhost

# ── Optional: Plane project-management integration ─────────────────────────
# PLANE_BASE_URL=
# PLANE_API_KEY=
# PLANE_WORKSPACE_SLUG=
