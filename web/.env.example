# Browser demo — environment template
#
# Copy this file to `.env` (which is gitignored) and fill in your local values.
# Only variables prefixed with VITE_ are exposed to the client bundle.
#
# SECURITY: every VITE_ value is baked into the public JS bundle. Put only
# non-secret config here — never a token, password, or API key. The login flow
# fetches the JWT at runtime and keeps it in memory.

# Base URL of the Arbi backend this demo talks to (production, staging, or
# development). No trailing slash and no `/api` suffix — the read adapter adds
# the correct path per endpoint. Empty means same-origin.
# Example: https://api.staging.arbi.example
VITE_API_BASE_URL=

# Optional: prefill the seeded demo login email on the sign-in screen.
# The backend seeds this user via the `browser-demo` profile.
VITE_DEMO_EMAIL=
