# ============================================================
# SECRETS — fill in real values; do not commit, do not share.
# ============================================================

# Database password — embedded in DATABASE_URL on the next line, keep them
# in sync if you change them. For any non-local deployment, change
# POSTGRES_PASSWORD to a real secret.
POSTGRES_PASSWORD=arbi
DATABASE_URL=postgresql+asyncpg://arbi:arbi@localhost:5432/arbi

# JWT signing key — generate a strong random 32+ byte value for production.
# In production (ENVIRONMENT=production) the app refuses to boot on the dev default.
JWT_SECRET=change-this-to-a-secure-random-32+byte-string

# Runtime environment: development | production
ENVIRONMENT=development
# Max accepted upload size, in megabytes.
MAX_UPLOAD_SIZE_MB=25

# ============================================================
# SAFE CONFIGURATION — okay to share / paste / commit
# ============================================================

# CORS — comma-separated exact origins allowed to call the API from a browser.
# Required for the web client (separate origin). Empty = CORS disabled.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database (PostgreSQL)
# Default targets the docker-compose Postgres service. For one-off scripts,
# override DATABASE_URL with `sqlite+aiosqlite:///./arbi.db` and the
# connection layer auto-switches dialect-specific behavior.
POSTGRES_USER=arbi
POSTGRES_DB=arbi

# Connection pool tunables. Ignored on SQLite (StaticPool single-conn).
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=10
# DATABASE_POOL_RECYCLE=1800

# Logging
# LOG_LEVEL=INFO

# LLM provider — "anthropic" (development) or "alibaba" (Qwen, production).
LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Alibaba Cloud Model Studio (DashScope) — Qwen via the OpenAI-compatible endpoint.
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen3.7-plus

# Plane — agent tool integration (self-hosted, API-key auth). All four needed
# for the Plane tools to make live calls; absent = tools return a clear error.
# PLANE_BASE_URL=https://plane.example.com
# PLANE_API_KEY=plane_api_...
# PLANE_WORKSPACE_SLUG=my-workspace
# PLANE_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Embeddings — OpenAI by default (1536-dim, matches the Qdrant collection).
EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Reranker — cross-encoder over retrieval results. Disable to skip the model
# load (falls back to a no-op passthrough).
# ENABLE_RERANKER=true
# RERANKER_MODEL=BAAI/bge-reranker-large

# Vector store (Qdrant). Use localhost outside Docker; the compose service
# name inside the full stack.
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=documents
# QDRANT_VECTOR_SIZE=1536
