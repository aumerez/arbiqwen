# ============================================================
# SECRETS — fill in real values; do not commit, do not share.
# ============================================================

# Database password — embedded in DATABASE_URL on the next line, keep them
# in sync if you change them. For any non-local deployment, change
# POSTGRES_PASSWORD to a real secret.
POSTGRES_PASSWORD=arbi
DATABASE_URL=postgresql+asyncpg://arbi:arbi@localhost:5432/arbi

# JWT signing key — generate a strong random 32+ byte value for production.
JWT_SECRET=change-this-to-a-secure-random-32+byte-string

# ============================================================
# SAFE CONFIGURATION — okay to share / paste / commit
# ============================================================

# Database (PostgreSQL)
# Default targets the docker-compose Postgres service. For one-off scripts,
# override DATABASE_URL with `sqlite+aiosqlite:///./arbi.db` and the
# connection layer auto-switches dialect-specific behavior.
POSTGRES_USER=arbi
POSTGRES_DB=arbi

# Connection pool tunables. Ignored on SQLite (StaticPool single-conn).
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=10
# DATABASE_POOL_RECYCLE=1800

# Logging
# LOG_LEVEL=INFO

# LLM provider — Anthropic Claude by default. Set the API key to make live calls.
LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings — OpenAI by default (1536-dim, matches the Qdrant collection).
EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Vector store (Qdrant). Use localhost outside Docker; the compose service
# name inside the full stack.
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=documents
# QDRANT_VECTOR_SIZE=1536
